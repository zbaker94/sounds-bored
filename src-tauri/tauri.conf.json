{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sounds-bored",
  "version": "0.1.0",
  "identifier": "com.beeswax.sounds-bored",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sounds-bored",
        "width": 1336,
        "height": 768
      }
    ],
    "security": {
      "csp": {
        "img-src": ["'self'", "asset:", "https://asset.localhost"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**", "$APP/**/*"] 
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
