{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sounds-bored",
  "version": "1.1.7",
  "identifier": "com.beeswax.sounds-bored",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sounds-bored",
        "width": 1336,
        "height": 900,
        "devtools": true
      }
    ],
    "security": {
      "csp": {
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "https://asset.localhost"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "https://asset.localhost"
        ],
        "connect-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "https://asset.localhost"
        ]
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/**",
          "$APP/**/*",
          "$MUSIC/**",
          "$HOME/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMUU3RUNEOTgxRjBBMjYKUldRbUNoK1l6WDRlbjZMTmh5OW5ETUQvWVlxTGpaa2RseTNRMUVNQ2RySFUxOVlmNHUxYjRPbTUK",
      "endpoints": [
        "https://github.com/zbaker94/sounds-bored-releases/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
