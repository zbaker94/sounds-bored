{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window. Shell plugin (tauri-plugin-shell) is intentionally absent from this list — all sidecar spawn/kill operations are Rust-side only (see src-tauri/src/commands.rs). Do not add shell:allow-spawn or shell:allow-kill here.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$AUDIO/**" },
        { "path": "$APPDATA/SoundsBored/**" },
        { "path": "$APPLOCALDATA/SoundsBored/**" }
      ]
    },
    "dialog:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:scope-appdata-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/SoundsBored/**" },
        { "path": "$APPLOCALDATA/SoundsBored/**" },
        { "path": "$AUDIO/**" }
      ]
    },
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-restart"
  ]
}
